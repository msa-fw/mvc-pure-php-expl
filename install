<?php

use System\Core\Database;
use System\Core\Console\Dialog;

define('CLI_MODE', __FILE__);

include_once __DIR__ . "/core.php";

new install();

class install
{
    protected $config = [
        'driver' => null,
        'locale' => 'en_US',
        'charset' => 'utf8mb4',
        'collate' => 'utf8mb4_unicode_520_ci',
        'engine' => 'MyISAM',
        'host' => null,
        'port' => null,
        'user' => null,
        'pass' => null,
        'base' => null,
        'socket' => null,
        'databaseMode' => [
            'STRICT_TRANS_TABLES',
            'NO_ZERO_IN_DATE',
            'NO_ZERO_DATE',
            'ERROR_FOR_DIVISION_BY_ZERO',
            'NO_ENGINE_SUBSTITUTION',
        ],
    ];

    public function __construct()
    {
        $this->setDatabase();
        if($this->saveConfig()){
            $this->copyFiles();
            $this->installDependencies();

            return unlink(__FILE__);
        }
        throw new Exception("Some error");
    }

    protected function setDatabase()
    {
        $this->setDbDriver();
        $this->setDbHost();
        $this->setDbPort();
        $this->setDbUser();
        $this->setDbPassword();
        $this->setDbDatabase();

        try{
            $db = $this->config['base'];
            $this->config['base'] = null;

            $database = new Database();
            $connection = $database->new('test', $this->config);

            $connection->database($db)->add();

            $this->config['base'] = $db;

            print \console\success("Connection to DB: OK");
            return true;
        }catch(Exception $exception){
            print \console\danger($exception->getMessage());
            $this->setDatabase();
        }
        return false;
    }

    protected function saveConfig()
    {
        $configFile = ROOT . "/.Controllers/Home/configs/config.php";
        if(file_exists($configFile)){
            $content = file_get_contents($configFile);
            $replace = [
                '[MYSQL_DRIVER]' => $this->config['driver'],
                '[MYSQL_HOST]' => $this->config['host'],
                '[MYSQL_PORT]' => $this->config['port'],
                '[MYSQL_USER]' => $this->config['user'],
                '[MYSQL_PASSWORD]' => $this->config['pass'],
                '[MYSQL_DATABASE]' => $this->config['base'],
            ];
            $content = str_replace(array_keys($replace), array_values($replace), $content);

            if(file_put_contents($configFile, $content)){
                return true;
            }
        }
        return false;
    }

    protected function copyFiles()
    {
        \filesystem\scan_callback(ROOT . "/.Controllers", function($directory, $file, $isDirectory){
            if($isDirectory){ return false; }

            $target = "{$directory}/{$file}";
            $destination = str_replace('/.Controllers/', '/Controllers/', $target);

            $destinationDirectory = dirname($destination);
            if(!is_dir($destinationDirectory)){
                mkdir($destinationDirectory, 0777, true);
            }

            return rename($target, $destination);
        });

        \filesystem\scan_callback(ROOT . "/.Controllers", function($directory, $file, $isDirectory){
            $path = $directory;
            if($file){ $path .= "/{$file}"; }

            if(file_exists($path)){
                if($isDirectory){
                    return rmdir($path);
                }
                return unlink($path);
            }
            return null;
        });

        rename(ROOT . "/_.htaccess", ROOT . "/.htaccess");
        return $this;
    }

    protected function installDependencies()
    {
        $output = shell_exec("composer --working-dir=" . __DIR__ . " install");
        print \console\success($output);
        return $this;
    }

    protected function setDbDriver()
    {
        $dialog = new Dialog("Enter Database driver (def: mysql)");
        $this->config['driver'] = $dialog->answer() ?: 'mysql';
        return $this;
    }
    protected function setDbHost()
    {
        $dialog = new Dialog("Enter Database host (def: localhost)");
        $this->config['host'] = $dialog->answer() ?: 'localhost';
        return $this;
    }
    protected function setDbPort()
    {
        $dialog = new Dialog("Enter Database port (def: 3306)");
        $this->config['port'] = $dialog->answer() ?: 3306;
        return $this;
    }
    protected function setDbUser()
    {
        $dialog = new Dialog("Enter Database user");
        $this->config['user'] = $dialog->answer();
        return $this;
    }
    protected function setDbPassword()
    {
        $dialog = new Dialog("Enter Database password");
        $this->config['pass'] = $dialog->answer();
        return $this;
    }
    protected function setDbDatabase()
    {
        $dialog = new Dialog("Enter Database database name (def: msa_fw_simple_db)");
        $this->config['base'] = $dialog->answer() ?: 'msa_fw_simple_db';
        return $this;
    }
}